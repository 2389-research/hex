{
  "hooks": {
    "SessionStart": {
      "command": "echo '=== Clem Session Started ===' >> .claude/session.log",
      "description": "Log session start",
      "ignoreFailure": true,
      "async": true
    },
    "SessionEnd": {
      "command": "echo '=== Clem Session Ended ===' >> .claude/session.log",
      "description": "Log session end",
      "ignoreFailure": true
    },
    "PostToolUse": [
      {
        "command": "gofmt -w ${CLAUDE_TOOL_FILE_PATH}",
        "description": "Auto-format Go files after editing",
        "match": {
          "toolName": "Edit",
          "filePattern": ".*\\.go$"
        },
        "timeout": 5000,
        "ignoreFailure": true
      },
      {
        "command": "biome format --write ${CLAUDE_TOOL_FILE_PATH}",
        "description": "Auto-format TypeScript/JavaScript files after editing",
        "match": {
          "toolName": "Edit",
          "filePattern": ".*\\.(ts|tsx|js|jsx)$"
        },
        "timeout": 5000,
        "ignoreFailure": true
      },
      {
        "command": "echo \"$(date -Iseconds) - ${CLAUDE_TOOL_NAME} ${CLAUDE_TOOL_FILE_PATH}\" >> .claude/tool-usage.log",
        "description": "Log all tool usage",
        "async": true,
        "ignoreFailure": true
      }
    ],
    "UserPromptSubmit": {
      "command": "echo \"$(date -Iseconds): USER - ${CLAUDE_MESSAGE_TEXT}\" >> .claude/conversation.log",
      "description": "Log user prompts",
      "async": true,
      "ignoreFailure": true
    },
    "PreToolUse": {
      "command": "cp ${CLAUDE_TOOL_FILE_PATH} ${CLAUDE_TOOL_FILE_PATH}.backup",
      "description": "Backup files before editing",
      "match": {
        "toolName": "Edit"
      },
      "ignoreFailure": true
    }
  }
}
