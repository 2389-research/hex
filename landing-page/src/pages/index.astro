---
// ABOUTME: Coming soon landing page for hex with mailing list signup
// ABOUTME: Cyberpunk terminal aesthetic with CRT effects
import Layout from '../layouts/Layout.astro';
---

<Layout title="hex">
  <!-- Hexagon background pattern -->
  <div class="hex-bg"></div>

  <!-- Floating particles -->
  <div class="fixed inset-0 pointer-events-none z-[-1] overflow-hidden">
    {Array.from({ length: 20 }).map((_, i) => (
      <div
        class="particle"
        style={`left: ${Math.random() * 100}%; animation-delay: ${Math.random() * 20}s; animation-duration: ${15 + Math.random() * 10}s;`}
      />
    ))}
  </div>

  <div class="flex flex-col items-center justify-center min-h-screen px-4">
    <!-- Main content -->
    <div class="text-center max-w-xl w-full">
      <!-- Prompt symbol -->
      <div class="fade-in-up delay-1 mb-6">
        <span class="text-text-ghost text-lg">$</span>
      </div>

      <!-- Logo -->
      <h1 class="fade-in-up delay-2 text-7xl md:text-9xl font-bold text-cyan glow tracking-tighter mb-16">
        hex
      </h1>

      <!-- Mailing List Form -->
      <div class="fade-in-up delay-3 mb-8">
        <div class="terminal-box">
          <div class="border-b border-border px-4 py-3 flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-red-500/60"></span>
            <span class="w-3 h-3 rounded-full bg-amber/60"></span>
            <span class="w-3 h-3 rounded-full bg-green/60"></span>
            <span class="ml-4 text-text-ghost text-sm">notify.sh</span>
          </div>

          <div class="p-6 space-y-4">
            <p class="text-text-dim text-sm text-center">
              Get notified when hex is ready.
            </p>
            <p class="text-text-ghost text-xs text-center">
              No spam. Unsubscribe anytime.
            </p>

            <form id="mailing-form" class="space-y-4">
              <div class="flex items-center gap-2">
                <span class="text-cyan">&gt;</span>
                <span class="text-text-ghost">email:</span>
                <input
                  type="email"
                  id="email-input"
                  placeholder="_"
                  class="flex-1 bg-transparent border-none outline-none min-w-0 text-text placeholder:text-text-ghost placeholder:animate-pulse"
                  required
                />
              </div>

              <button
                type="submit"
                id="submit-btn"
                class="w-full glitch-btn py-3"
              >
                <span class="text-text-ghost">[</span>
                <span id="btn-text">SUBSCRIBE</span>
                <span class="text-text-ghost">]</span>
              </button>

              <p id="form-message" class="text-sm text-center hidden"></p>
            </form>
          </div>
        </div>
      </div>

      <!-- Contact -->
      <div class="fade-in-up delay-4">
        <p class="text-text-ghost text-sm">
          Questions? <a href="mailto:hello@2389.ai" class="text-cyan hover:underline">hello@2389.ai</a>
        </p>
      </div>
    </div>

    <!-- Footer -->
    <div class="absolute bottom-8 left-0 right-0 text-center">
      <p class="text-text-ghost text-sm">
        <a href="https://2389.ai" class="hover:text-cyan transition-colors">2389 Research Inc</a>
      </p>
    </div>
  </div>

  <!-- ASCII art decoration (hidden on mobile) -->
  <div class="hidden lg:block fixed bottom-8 left-8 text-text-ghost/20 text-xs font-mono leading-tight select-none">
    <pre>{`
  ╭─────────────────╮
  │  ◆ hex v0.0.1  │
  │  status: boot  │
  ╰─────────────────╯
    `}</pre>
  </div>

  <div class="hidden lg:block fixed bottom-8 right-8 text-text-ghost/20 text-xs font-mono leading-tight select-none text-right">
    <pre>{`
┌──────────────────┐
│ SYS.READY        │
│ MEM: ████████░░  │
│ CPU: ██████░░░░  │
└──────────────────┘
    `}</pre>
  </div>
</Layout>

<script>
  const form = document.getElementById('mailing-form') as HTMLFormElement;
  const emailInput = document.getElementById('email-input') as HTMLInputElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text') as HTMLSpanElement;
  const formMessage = document.getElementById('form-message') as HTMLParagraphElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const email = emailInput.value.trim();
    if (!email) return;

    // Validate email
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      formMessage.textContent = '✗ invalid email format';
      formMessage.className = 'text-sm text-center text-red-400';
      formMessage.classList.remove('hidden');
      return;
    }

    // Show loading state
    btnText.textContent = '...';
    submitBtn.disabled = true;

    try {
      const response = await fetch('https://buttondown.com/api/emails/embed-subscribe/2389', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: new URLSearchParams({ email }).toString(),
      });

      if (response.ok) {
        formMessage.textContent = '✓ you\'re on the list';
        formMessage.className = 'text-sm text-center text-green';
        formMessage.classList.remove('hidden');
        emailInput.value = '';
        btnText.textContent = 'SUBSCRIBED';
      } else {
        formMessage.textContent = '✗ subscription failed';
        formMessage.className = 'text-sm text-center text-red-400';
        formMessage.classList.remove('hidden');
        btnText.textContent = 'SUBSCRIBE';
        submitBtn.disabled = false;
      }
    } catch {
      formMessage.textContent = '✗ network error';
      formMessage.className = 'text-sm text-center text-red-400';
      formMessage.classList.remove('hidden');
      btnText.textContent = 'SUBSCRIBE';
      submitBtn.disabled = false;
    }
  });
</script>
